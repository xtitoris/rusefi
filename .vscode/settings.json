{
    "files.associations": {
		"*.input": "ini",
		"array": "cpp",
		"*.tcc": "cpp",
		"memory": "cpp",
		"istream": "cpp",
		"functional": "cpp",
		"tuple": "cpp",
		"utility": "cpp",
		"variant": "cpp",
		"format": "cpp"
	},
	"editor.detectIndentation": false,
	"editor.indentSize": 4,
	"editor.tabSize": 4,
	"editor.insertSpaces": false,
	"files.exclude": {
		"**/.dep": true,
		"**/build/lst": true,
		"**/build/obj": true,
		"hardware/": true,
	},
	"search.exclude": {
		"**/.dep": true,
		"**/build/lst": true,
		"**/build/obj": true,
		"hardware/": true,
		"firmware/ChibiOS/demos": true,
	},
	"cSpell.words": [
		"IACV"
	],
	"files.associations": {
		"*.input": "ini"
	},
	"C_Cpp.formatting": "vcFormat",
	"Lua.diagnostics.disable": [
		"lowercase-global"
	],
	"testMate.cpp.test.advancedExecutables": [
		{
			"pattern": "*/build/**/*{test,Test}",
			"cwd": "${absDirpath}/../",
			"runTask": { "before": ["Build Unit Tests (pixi)"] }
		}
    ],
    "testMate.cpp.debug.configTemplate": {
        "type": "lldb",
        "request": "launch",
        "name": "TestMate Debug Backend",
        "program": "${exec}", 
        "args": "${args}",
        "cwd": "${absDirpath}/../"
    }
}
